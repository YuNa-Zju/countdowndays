{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Momentary",
  "version": "1.1.12",
  "identifier": "com.yuna.momentary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/YuNa-Zju/countdowndays/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2ODg3NDU0RTIzMjQxNDEKUldSQlFUTGlWSFNJZGdKVDFBNFlPMkFMdHBGbUhMTkxHaU9ORTNBWUJOd1d2amlzSDdydkpmeVIK"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 1080,
        "resizable": true,
        "title": "Momentary",
        "width": 1440,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false
      },
      {
        "label": "fab",
        "title": "FabWidget",
        "width": 10,
        "height": 10,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      },
      {
        "title": "Momentary Tray",
        "width": 260,
        "height": 320,
        "label": "tray",
        "transparent": true,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "center": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
